// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  USER 
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String

  savedItems  SavedCollege[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model College {
  id            String   @id @default(cuid())

  name          String
  location      String

  fees          Int

  rating        Float

  overview      String

  placements    String

  imageUrl      String?

  courses       Course[]

  reviews       Review[]

  savedBy       SavedCollege[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())

  name        String

  duration    String

  fees        Int

  collegeId   String

  college     College  @relation(fields: [collegeId], references: [id])

  createdAt   DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())

  comment     String

  rating      Int

  userName    String

  collegeId   String

  college     College @relation(fields: [collegeId], references: [id])

  createdAt   DateTime @default(now())
}

model SavedCollege {
  id          String   @id @default(cuid())

  userId      String

  collegeId   String

  user        User     @relation(fields: [userId], references: [id])

  college     College  @relation(fields: [collegeId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([userId, collegeId])
}